# NexusQuant Environment Configuration
# Copy to /opt/nexusquant/env or .env

# Upstox OAuth
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://www.jashuvatrade.xyz/api/upstox/callback

# Redis
REDIS_URL=redis://localhost:6379/0

# News
NEWS_PROVIDER=finnhub
FINNHUB_API_KEY=

# Safety — production defaults
ENABLE_LIVE_TRADING=false
PAPER_TRADING=true
AUTO_TRADING_ENABLED=true
SHADOW_TRADE_ALL_SIGNALS=true

# Data cadence
MARKET_POLL_SECONDS=1
SNAPSHOT_CACHE_SECONDS=1
UPSTOX_MIN_REQUEST_INTERVAL_MS=150
UPSTOX_CHAIN_CACHE_SECONDS=15
UPSTOX_MAX_EXPIRY_PROBES=2
CAPITAL_REFRESH_SECONDS=60
BACKGROUND_MARKET_MONITOR_ENABLED=true
COMPOSER_MONITOR_ENABLED=true
CURSOR_API_KEY=

# Trading mode
PAPER_SIMPLE_PROFIT_MODE=true
PAPER_DUAL_STRATEGY_ENABLED=false

# Enhanced scalping (more powerful than base)
ENHANCED_MICRO_TARGET_POINTS=2.5
ENHANCED_VELOCITY_THRESHOLD=1.2
ENHANCED_TQS_ENTRY=50
ADAPTIVE_TARGET_ENABLED=true
TICK_FUSION_ENABLED=true

# Capital — 66% margin per trade; lots sized per index (NIFTY=65, BANKNIFTY=30, SENSEX=20)
FALLBACK_CAPITAL_INR=500000
PER_TRADE_CAPITAL_PCT=0.66
AGGRESSIVE_LOT_SIZING=true
AGGRESSIVE_MIN_TQS=50
AGGRESSIVE_MIN_EXPLOSION_SCORE=45
AGGRESSIVE_MAX_OPEN_SCALPS=1
POSITION_SL_CAP_PCT=0.06
POSITION_TP_TARGET_PCT=0.10
USE_UPSTOX_CAPITAL_FOR_SIZING=true

# Quantity per lot (units) — current NSE/BSE sizes
LOT_SIZE_NIFTY=65
LOT_SIZE_BANKNIFTY=30
LOT_SIZE_SENSEX=20
USE_UPSTOX_LOT_SIZES=false

MIN_OPTION_PREMIUM_INR=25
MAX_OPTION_PREMIUM_INR=100
MIN_LOTS_PER_TRADE=25
MAX_LOTS_PER_TRADE=100
SIMPLE_MAX_LOTS=100
SIMPLE_TARGET_LOTS=60
SIMPLE_MIN_LOTS=25
SWING_MIN_LOTS=25
SWING_TARGET_LOTS=75

# Persistence — every paper/live trade is appended to trades.log
TRADE_STORE_DIR=/opt/nexusquant/data/trades
# TRADE_LOG_FILE=/opt/nexusquant/data/trades/trades.log  # optional override
DAILY_TOKEN_ONCE=true

# ── Live deployment (arm only after paper validation) ──
# 1. Verify trades.log on EC2 has expected paper entries
# 2. Confirm /api/deployment/readiness returns readyForLive=true
# 3. Set below and redeploy backend:
# ENABLE_LIVE_TRADING=true
# PAPER_TRADING=false   # optional — journal still logs executionMode=LIVE

# Swing trading (multi-day paper holds)
SWING_TRADING_ENABLED=true
SWING_MAX_HOLD_DAYS=5
SWING_TARGET_PCT=30
SWING_STOP_PCT=12

COMMIT_SHA=dev
ENVIRONMENT=development
