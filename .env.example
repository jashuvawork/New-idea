# NexusQuant Environment Configuration
# Copy to /opt/nexusquant/env or .env

# Upstox OAuth
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://www.jashuvatrade.xyz/api/upstox/callback

# Redis
REDIS_URL=redis://localhost:6379/0

# News
NEWS_PROVIDER=finnhub
FINNHUB_API_KEY=

# Safety — production defaults
ENABLE_LIVE_TRADING=false
PAPER_TRADING=true
SHADOW_TRADE_ALL_SIGNALS=true

# Data cadence
MARKET_POLL_SECONDS=3
SNAPSHOT_CACHE_SECONDS=3
BACKGROUND_MARKET_MONITOR_ENABLED=true

# Trading mode
PAPER_SIMPLE_PROFIT_MODE=true
PAPER_DUAL_STRATEGY_ENABLED=false

# Enhanced scalping (more powerful than base)
ENHANCED_MICRO_TARGET_POINTS=2.5
ENHANCED_VELOCITY_THRESHOLD=1.8
ENHANCED_TQS_ENTRY=68
ADAPTIVE_TARGET_ENABLED=true
TICK_FUSION_ENABLED=true

# Capital / risk
DEFAULT_CAPITAL_INR=500000
MAX_RISK_PER_TRADE_INR=12000
EMERGENCY_STOP_INR=18000
SIMPLE_MAX_LOTS=14
SIMPLE_TARGET_LOTS=10
SIMPLE_MIN_LOTS=6

# Persistence
TRADE_STORE_DIR=/opt/nexusquant/data/trades
DAILY_TOKEN_ONCE=true

COMMIT_SHA=dev
ENVIRONMENT=development
