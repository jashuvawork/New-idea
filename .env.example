# NexusQuant Environment Configuration
# Copy to /opt/nexusquant/env or .env

# Upstox OAuth
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://www.jashuvatrade.xyz/api/upstox/callback

# Redis
REDIS_URL=redis://localhost:6379/0

# News
NEWS_PROVIDER=finnhub
FINNHUB_API_KEY=

# Safety — production defaults
ENABLE_LIVE_TRADING=false
PAPER_TRADING=true
AUTO_TRADING_ENABLED=true
SHADOW_TRADE_ALL_SIGNALS=true

# Data cadence
MARKET_POLL_SECONDS=5
SNAPSHOT_CACHE_SECONDS=5
UPSTOX_MIN_REQUEST_INTERVAL_MS=150
UPSTOX_CHAIN_CACHE_SECONDS=15
UPSTOX_MAX_EXPIRY_PROBES=2
CAPITAL_REFRESH_SECONDS=60
BACKGROUND_MARKET_MONITOR_ENABLED=true

# Trading mode
PAPER_SIMPLE_PROFIT_MODE=true
PAPER_DUAL_STRATEGY_ENABLED=false

# Enhanced scalping (more powerful than base)
ENHANCED_MICRO_TARGET_POINTS=2.5
ENHANCED_VELOCITY_THRESHOLD=1.8
ENHANCED_TQS_ENTRY=68
ADAPTIVE_TARGET_ENABLED=true
TICK_FUSION_ENABLED=true

# Capital — 50% per trade, max lots from Upstox margin
FALLBACK_CAPITAL_INR=500000
PER_TRADE_CAPITAL_PCT=0.50
AGGRESSIVE_LOT_SIZING=true
AGGRESSIVE_MIN_TQS=78
AGGRESSIVE_MIN_EXPLOSION_SCORE=70
AGGRESSIVE_MAX_OPEN_SCALPS=1
POSITION_SL_CAP_PCT=0.06
POSITION_TP_TARGET_PCT=0.10
USE_UPSTOX_CAPITAL_FOR_SIZING=true

SIMPLE_MAX_LOTS=14
SIMPLE_TARGET_LOTS=10
SIMPLE_MIN_LOTS=6

# Persistence
TRADE_STORE_DIR=/opt/nexusquant/data/trades
DAILY_TOKEN_ONCE=true

# Swing trading (multi-day paper holds)
SWING_TRADING_ENABLED=true
SWING_MAX_HOLD_DAYS=5
SWING_TARGET_PCT=30
SWING_STOP_PCT=12

COMMIT_SHA=dev
ENVIRONMENT=development
